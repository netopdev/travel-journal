# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: use your local Postgres instance
# Production: use 127.0.0.1 (Postgres is not exposed publicly on the server)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/travel_journal

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=paste-output-here

# The one email address that is allowed to log in as admin
ADMIN_EMAIL=netop.tech.dev@gmail.com

# ── Email / magic links (Resend) ──────────────────────────────────────────────
# Sign up free at resend.com → API Keys → Create key
RESEND_API_KEY=re_xxxxxxxxxxxx

# Must be a verified domain in your Resend account
EMAIL_FROM=noreply@yourdomain.com

# ── Production only (add to .env.production on the server) ───────────────────
# Tells Auth.js the canonical URL so magic-link callbacks work behind Caddy
# AUTH_URL=https://yourdomain.com
